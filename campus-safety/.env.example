# Copy to .env and adjust for your environment
# cp .env.example .env

# API authentication (optional in dev; recommended in production)
# API_KEY=change-me-to-a-random-string

# YOLO inference device: cuda | cpu | auto
YOLO_DEVICE=cuda

# HuggingFace mirror (optional, useful in China)
# HF_ENDPOINT=https://hf-mirror.com

# Structured JSON logging
LOG_JSON=0

# Frontend API base (production build only)
# VITE_API_BASE_URL=http://localhost:8000/api

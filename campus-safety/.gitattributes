# Normalize line endings
* text=auto

# Python sources
*.py text eol=lf
*.sh text eol=lf

# Windows scripts
*.bat text eol=crlf

# Binary assets
*.pt filter=lfs diff=lfs merge=lfs -text
*.onnx filter=lfs diff=lfs merge=lfs -text
*.engine filter=lfs diff=lfs merge=lfs -text
*.mp4 binary
*.jpg binary
*.png binary
